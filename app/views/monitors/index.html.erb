<div class="flex min-h-screen">
  <%= render "partials/sidebar" %>

  <div class="flex-1 p-6">

  <section class="text-gray-600 body-font pb-4">
      <div class="flex flex-wrap -m-4">
        <div class="xl:w-1/4 md:w-1/2 p-4">
          <div class="bg-background/50 border border-secondary/10 p-6">
            <h3 class="tracking-widest text-indigo-500 text-xs font-medium title-font">SUBTITLE</h3>
            <h2 class="text-lg text-gray-900 font-medium title-font mb-4">Chichen Itza</h2>
          </div>
        </div>
        <div class="xl:w-1/4 md:w-1/2 p-4">
          <div class="bg-background/50 border border-secondary/10 p-6">
            <h3 class="tracking-widest text-indigo-500 text-xs font-medium title-font">SUBTITLE</h3>
            <h2 class="text-lg text-gray-900 font-medium title-font mb-4">Chichen Itza</h2>
          </div>
        </div>
        <div class="xl:w-1/4 md:w-1/2 p-4">
          <div class="bg-background/50 border border-secondary/10 p-6">
            <h3 class="tracking-widest text-indigo-500 text-xs font-medium title-font">SUBTITLE</h3>
            <h2 class="text-lg text-gray-900 font-medium title-font mb-4">Chichen Itza</h2>
          </div>
        </div>
        <div class="xl:w-1/4 md:w-1/2 p-4">
          <div class="bg-background/50 border border-secondary/10 p-6">
            <h3 class="tracking-widest text-indigo-500 text-xs font-medium title-font">SUBTITLE</h3>
            <h2 class="text-lg text-gray-900 font-medium title-font mb-4">Chichen Itza</h2>
          </div>
        </div>
      </div>
  </section>  

    <!-- Top Bar -->
    <div class="flex flex-wrap flex-col md:flex-row items-center justify-between mb-6 gap-4">

      <div class="relative w-full md:w-80">
        <label class="text-sm text-gray-600">Search Monitors</label>
        <input
          type="text"
          placeholder="Search by URL"
          class="w-full border border-secondary/10 px-3 py-2 focus:ring-2 focus:ring-secondary/10 focus:outline-none"
        >
      </div>

      <%= render "partials/primary_button", value: "Create Monitor", url_path: new_monitor_path %>

    </div>


    <!-- Monitors Table -->
    <div class="bg-white border border-secondary/10 overflow-hidden">

      <table class="w-full text-sm">

        <!-- Table Header -->
        <thead class="bg-background border-b border-secondary/10 text-gray-600">
          <tr>
            <th class="text-left px-6 py-3 font-medium">Monitor</th>
            <th class="text-left px-6 py-3 font-medium">Type</th>
            <th class="text-left px-6 py-3 font-medium">Interval</th>
            <th class="text-left px-6 py-3 font-medium">Status Page</th>
            <th class="text-left px-6 py-3 font-medium">Created</th>
            <th class="text-right px-6 py-3 font-medium">Actions</th>
          </tr>
        </thead>

        <!-- Table Body -->
        <tbody class="divide-y divide-secondary/10">
          <% if @pulses.any? %>
            <% @pulses.each do |pulse| %>

              <tr class="hover:bg-background/40 transition">

                <!-- URL -->
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">

                    <!-- Globe Icon -->
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2"
                        viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="10"/>
                      <line x1="2" y1="12" x2="22" y2="12"/>
                    </svg>

                    <span class="font-medium text-gray-900">
                      <%= pulse.url %>
                    </span>

                  </div>
                </td>


                <!-- Monitor Type -->
                <td class="px-6 py-4 text-gray-600">
                  <% types = {0 => "HTTP", 1 => "Ping", 2 => "Keyword"} %>
                  <span class="px-2 py-1 text-xs rounded bg-gray-100">
                    <%= types[pulse.pulse_type] %>
                  </span>
                </td>


                <!-- Interval -->
                <td class="px-6 py-4 text-gray-600">
                  <%= pulse.pulse_interval %> min
                </td>


                <!-- Status Page -->
                <td class="px-6 py-4">

                  <% if pulse.status_page %>
                    <span class="flex items-center gap-2 text-green-600 text-sm">

                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M16.707 5.293a1 1 0 00-1.414 0L8 12.586 4.707 9.293a1 1 0 00-1.414 1.414l4 4
                        a1 1 0 001.414 0l8-8a1 1 0 000-1.414z"/>
                      </svg>

                      Enabled
                    </span>

                  <% else %>

                    <span class="text-gray-400 text-sm">
                      Disabled
                    </span>

                  <% end %>

                </td>


                <!-- Created -->
                <td class="px-6 py-4 text-gray-500">
                  <%= time_ago_in_words(pulse.created_at) %> ago
                </td>


                <!-- Actions -->
                <td class="px-6 py-4 text-right">

                  <div class="flex justify-end gap-3">

                    <!-- Edit -->
                    <%= link_to edit_monitor_path(pulse), class: "text-gray-400 hover:text-gray-700" do %>
                      ✏️
                    <% end %>

                    <!-- Delete -->
                    <%= button_to monitor_path(pulse), method: :delete, class: "text-red-400 hover:text-red-600" do %>
                      🗑
                    <% end %>

                  </div>

                </td>

              </tr>

            <% end %>
          <% else %>
          <tr class="hover:bg-gray-50 transition text-center py-4">
            <p>No monitor found!</p>  
          </tr>
          <% end %>
        </tbody>

      </table>

    </div>

  </div>
</div>